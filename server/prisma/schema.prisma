generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  password          String
  avatar            String?
  resetToken        String?    @map("reset_token")
  resetTokenExpires DateTime?  @map("reset_token_expires")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  documents     Document[]
  conversations Conversation[]
  feedbacks     ChatFeedback[]

  @@map("users")
}

model Document {
  id         String           @id @default(uuid())
  title      String
  content    String           @db.LongText
  preview    String?
  category   DocumentCategory @default(general)
  isFavorite Boolean          @default(false) @map("is_favorite")
  isDeleted  Boolean          @default(false) @map("is_deleted")
  deletedAt  DateTime?        @map("deleted_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDeleted])
  @@map("documents")
}

enum DocumentCategory {
  sciFi
  fantasy
  design
  journal
  planning
  research
  general
}

model Conversation {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  messages   Json
  personality String  @default("normal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conversations")
}

model ChatFeedback {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  messageContent String @map("message_content") @db.LongText
  feedbackType String  @map("feedback_type") // "like" | "dislike"
  rating     Int?     // 1-5 for likes
  reason     String?  // for dislikes: reason text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_feedbacks")
}
